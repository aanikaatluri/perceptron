# Copy this file to .env and fill in your real key.
# .env is gitignored, so your key stays out of source control.
#
# For Hugging Face Spaces, add secrets under Settings → Repository secrets.
PERCEPTRON_API_KEY=your_key_here

# Optional: Perceptron HTTP timeout in seconds (default 300; video analysis can be slow)
# PERCEPTRON_TIMEOUT=300

# Optional: Langfuse observability (latency, structured outputs, user feedback)
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
